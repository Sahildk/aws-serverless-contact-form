# Copy this file to .env and fill in your values.
# These values are set as Lambda Environment Variables via the SAM template.

# The email address that will RECEIVE contact form submissions (must be SES-verified)
RECIPIENT_EMAIL=you@example.com

# The email address that will SEND the notification (must be SES-verified)
SENDER_EMAIL=noreply@yourdomain.com

# AWS Region where SES is configured
AWS_REGION=us-east-1
